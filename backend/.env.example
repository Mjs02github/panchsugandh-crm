# ============================================================
# Panchsugandh CRM — Backend Environment Variables
# Copy this file: cp .env.example .env
# Fill in your Hostinger MySQL credentials before running.
# ============================================================

# ── Server ───────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── Hostinger MySQL ──────────────────────────────────────────
# Find these in Hostinger hPanel → Databases → MySQL Databases
#
# DB_HOST options:
#   • If the Node.js app runs on the SAME Hostinger server → use: localhost
#   • If connecting REMOTELY (e.g. from your laptop)       → use: srv<number>.hstgr.io
#     (Enable remote MySQL access in hPanel first)
#
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_username       # e.g. u123456789_pcrm
DB_PASSWORD=your_db_password
DB_NAME=your_db_name           # e.g. u123456789_panchsugandh

# ── JWT ─────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_string_minimum_48_characters
JWT_EXPIRES_IN=8h

# ── CORS ─────────────────────────────────────────────────────
# Allowed frontend origin
# Development:   http://localhost:5173
# Production:    https://yourdomain.com
FRONTEND_URL=http://localhost:5173
